      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (country) (count_over_time({job=\"s7pot\", intent=\"GEO_ENRICHMENT\"}[$__range]))",
          "legendFormat": "{{country}}",
          "refId": "A",
          "instant": true
        }
