    {
      "id": 20,
      "type": "table",
      "title": "Top Attacker IPs",
      "description": "Source IPs with the most connections.",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Value #A",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "source_ip"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "IP Address"
              },
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Event Count"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-RdYlGr"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (source_ip) (count_over_time({job=\"s7pot\", protocol=\"S7COMM\"}[$__range]))",
          "legendFormat": "{{source_ip}}",
          "refId": "A",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "displayName": "Value #A",
                "desc": true
              }
            ]
          }
        }
      ]
    },
