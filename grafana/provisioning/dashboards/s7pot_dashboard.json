      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (intent) (count_over_time({job=\"s7pot\"}[1m]))",
          "legendFormat": "{{intent}}",
          "refId": "A"
        }
