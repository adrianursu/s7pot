    {
      "id": 25,
      "type": "geomap",
      "title": "🌍 Attacker World Map",
      "description": "Geographic origin of attackers based on GeoIP enrichment. Populated by real external IPs (private/loopback IPs excluded).",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 16,
        "h": 14
      },
      "options": {
        "view": {
          "id": "zero",
          "lat": 20,
          "lon": 10,
          "zoom": 2
        },
        "controls": {
          "mouseWheelZoom": true,
          "showAttribution": true,
          "showDebug": false,
          "showMeasure": false,
          "showScale": true,
          "showZoom": true
        },
        "tooltip": {
          "mode": "details"
        },
        "basemap": {
          "type": "default",
          "name": "Basemap",
          "config": {}
        },
        "layers": [
          {
            "type": "markers",
            "name": "Attackers",
            "config": {
              "style": {
                "size": {
                  "fixed": 10,
                  "min": 4,
                  "max": 20
                },
                "color": {
                  "fixed": "red"
                },
                "opacity": 0.7,
                "symbol": {
                  "mode": "fixed",
                  "fixed": "img/icons/marker/circle.svg"
                },
                "textConfig": {
                  "textAlign": "center",
                  "textBaseline": "middle"
                }
              },
              "showLegend": true
            },
            "location": {
              "mode": "coords",
              "latitude": "latitude",
              "longitude": "longitude"
            },
            "tooltip": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels",
            "replace": false
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "latitude",
                "destinationType": "number"
              },
              {
                "targetField": "longitude",
                "destinationType": "number"
              }
            ]
          }
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{job=\"s7pot\", intent=\"GEO_ENRICHMENT\"} | json latitude, longitude, country, city, source_ip, isp",
          "refId": "A",
          "instant": false
        }
      ]
    },
    {
      "id": 26,
      "type": "table",
