      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{job=\"s7pot\"} | json | intent =~ \"EXPLOIT_TRIGGERED|CRITICAL_OVERFLOW_ALARM|CVE-2019-10929 PROBE|CONNECTION_DETECTED\"",
          "refId": "A"
        }
